{
  "name": "duplicate-and-link",
  "displayName": "Duplicate Files and make Lnk",
  "description": "Duplicate files and directories.",
  "version": "1.2.0",
  "publisher": "Zulllus",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "duplicate",
    "copy",
    "file",
    "directory"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Zulllus/vscode-duplicate.git"
  },
  "homepage": "https://github.com/Zulllus/vscode-duplicate#readme",
  "icon": "logo.png",
  "main": "./out/extension.js",
  "l10n": "./lang",
  "contributes": {
    "customEditors": [
      {
        "viewType": "lnk.connector",
        "displayName": "Windows LNK Redirector",
        "selector": [
          {
            "filenamePattern": "*.lnk"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "duplicate-and-link.execute",
        "title": "%extension.duplicate.title%"
      },
      {
        "command": "duplicate-and-link.duplicateAsShortcut",
        "title": "%extension.duplicateShortcut.title%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "duplicate-and-link.execute",
          "group": "5_cutcopypaste@99"
        },
        {
          "command": "duplicate-and-link.duplicateAsShortcut",
          "group": "5_cutcopypaste@100",
          "when": "explorerResourceIsFolder == false"
        }
      ]
    },
    "configuration": [
      {
        "title": "%extension.duplicate.title%",
        "properties": {
          "duplicate-and-link.openFile": {
            "type": "boolean",
            "default": true,
            "title": "%extension.duplicate.config.open.title%",
            "description": "%extension.duplicate.config.open.desc%"
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "extest setup-and-run './out/test/test-*.js' --storage .vscode-test --extensions_dir .vscode-test/extensions --code_settings src/test/settings.json",
    "package": "vsce package"
  },
  "devDependencies": {
    "@actcoding/eslint-config": "^0.0.11",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@types/iconv-lite": "^0.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.3",
    "@types/vscode": "1.90.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.6.2",
    "eslint": "^9.39.0",
    "glob": "^11.0.3",
    "husky": "^9.1.7",
    "mocha": "^11.7.4",
    "typescript": "^5.9.3",
    "vscode-extension-tester": "^8.19.0"
  },
  "dependencies": {
    "iconv-lite": "^0.7.2",
    "windows-shortcuts": "^0.1.6"
  }
}
